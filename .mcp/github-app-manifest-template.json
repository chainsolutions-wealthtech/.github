{
  "name": "WealthTech MCP Governance App",
  "url": "https://mcp.wealthtechinnovations.com",
  "hook_attributes": {
    "url": "https://mcp.wealthtechinnovations.com/github/webhook"
  },
  "redirect_url": "https://mcp.wealthtechinnovations.com/github/callback",
  "public": false,
  "default_permissions": {
    "metadata": "read",
    "contents": "write",
    "pull_requests": "write",
    "issues": "write",
    "actions": "read",
    "checks": "read",
    "statuses": "write",
    "workflows": "write",
    "codespaces": "write",
    "organization_projects": "write",
    "organization_hooks": "write",
    "members": "read"
  },
  "default_events": [
    "push",
    "pull_request",
    "issues",
    "repository",
    "workflow_run",
    "check_run",
    "check_suite"
  ]
}
